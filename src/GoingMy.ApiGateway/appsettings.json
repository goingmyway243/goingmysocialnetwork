{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "CorsOrigins": "http://localhost:4200,https://localhost:4200",
  "OpenIddict": {
    "Issuer": "https://localhost:7001"
  },
  "ReverseProxy": {
    "Routes": {
      "route-auth-connect": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "api-rate-limit",
        "Match": {
          "Path": "/connect/{**catch-all}"
        }
      },
      "route-auth-api": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "api-rate-limit",
        "Match": {
          "Path": "/api/user/{**catch-all}"
        }
      },
      "route-user-api": {
        "ClusterId": "user-cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "api-rate-limit",
        "Match": {
          "Path": "/api/userprofiles/{**catch-all}"
        }
      },
      "route-post-api": {
        "ClusterId": "post-cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "api-rate-limit",
        "Match": {
          "Path": "/api/posts/{**catch-all}"
        }
      },
      "route-chat-api": {
        "ClusterId": "chat-cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "api-rate-limit",
        "Match": {
          "Path": "/api/chat/{**catch-all}"
        }
      },
      "route-chat-hub": {
        "ClusterId": "chat-cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "api-rate-limit",
        "Match": {
          "Path": "/hubs/chat/{**catch-all}"
        }
      },
      "route-admin-auth": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "admin-policy",
        "RateLimiterPolicy": "api-rate-limit",
        "Order": -1,
        "Match": {
          "Path": "/api/admin/{**catch-all}"
        }
      },
      "route-admin-posts-stats": {
        "ClusterId": "post-cluster",
        "AuthorizationPolicy": "admin-policy",
        "RateLimiterPolicy": "api-rate-limit",
        "Order": -1,
        "Match": {
          "Path": "/api/posts/admin/{**catch-all}"
        }
      },
      "route-upload-api": {
        "ClusterId": "upload-cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "api-rate-limit",
        "Match": {
          "Path": "/api/uploads/{**catch-all}"
        }
      },
      "route-upload-files": {
        "ClusterId": "upload-cluster",
        "Methods": [ "GET" ],
        "Match": {
          "Path": "/uploads/{**catch-all}"
        }
      },
      "route-notification-api": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "api-rate-limit",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      },
      "route-notification-hub": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "api-rate-limit",
        "Match": {
          "Path": "/hubs/notification/{**catch-all}"
        }
      },
      "route-search-api": {
        "ClusterId": "search-cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "api-rate-limit",
        "Match": {
          "Path": "/api/search/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-api": {
            "Address": "https+http://identity-api"
          }
        }
      },
      "user-cluster": {
        "Destinations": {
          "user-api": {
            "Address": "https+http://user-api"
          }
        }
      },
      "post-cluster": {
        "Destinations": {
          "post-api": {
            "Address": "https+http://post-api"
          }
        }
      },
      "chat-cluster": {
        "Destinations": {
          "chat-api": {
            "Address": "https+http://chat-api"
          }
        }
      },
      "upload-cluster": {
        "Destinations": {
          "upload-api": {
            "Address": "https+http://upload-api"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-api": {
            "Address": "https+http://notification-api"
          }
        }
      },
      "search-cluster": {
        "Destinations": {
          "search-api": {
            "Address": "https+http://search-api"
          }
        }
      }
    }
  }
}