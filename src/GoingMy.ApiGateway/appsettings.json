{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "http://localhost:4200,https://localhost:4200",
  "OpenIddict": {
    "Issuer": "https://localhost:7001"
  },
  "ReverseProxy": {
    "Routes": {
      "route-auth-connect": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "api-rate-limit",
        "Match": {
          "Path": "/connect/{**catch-all}"
        }
      },
      "route-auth-api": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "api-rate-limit",
        "Match": {
          "Path": "/api/user/{**catch-all}"
        }
      },
      "route-user-api": {
        "ClusterId": "user-cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "api-rate-limit",
        "Match": {
          "Path": "/api/userprofiles/{**catch-all}"
        }
      },
      "route-post-api": {
        "ClusterId": "post-cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "api-rate-limit",
        "Match": {
          "Path": "/api/posts/{**catch-all}"
        }
      },
      "route-chat-api": {
        "ClusterId": "chat-cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "api-rate-limit",
        "Match": {
          "Path": "/api/chat/{**catch-all}"
        }
      },
      "route-chat-hub": {
        "ClusterId": "chat-cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "api-rate-limit",
        "Match": {
          "Path": "/hubs/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-api": {
            "Address": "https://identity-api"
          }
        }
      },
      "user-cluster": {
        "Destinations": {
          "user-api": {
            "Address": "https://user-api"
          }
        }
      },
      "post-cluster": {
        "Destinations": {
          "post-api": {
            "Address": "https://post-api"
          }
        }
      },
      "chat-cluster": {
        "Destinations": {
          "chat-api": {
            "Address": "https://chat-api"
          }
        }
      }
    }
  }
}
