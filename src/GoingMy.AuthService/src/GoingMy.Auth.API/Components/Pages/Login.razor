@page "/"
@page "/login"
@using GoingMy.Auth.API.Services
@using GoingMy.Auth.API.Models
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using Microsoft.AspNetCore.Identity
@using System.ComponentModel.DataAnnotations
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager NavManager
@inject IHttpContextAccessor HttpContextAccessor

<div class="login-container">
    <!-- Animated gradient background -->
    <div class="gradient-bg"></div>
    <div class="gradient-bg-overlay"></div>

    <!-- Glass card -->
    <div class="glass glass-card">
        <div class="card-header">
            <h1 class="title">Welcome Back</h1>
            <p class="subtitle">Sign in to continue to your account</p>
        </div>

        <EditForm Model="Model" FormName="login-form" OnValidSubmit="OnValidSubmit" OnInvalidSubmit="OnInvalidSubmit" class="login-form">
            <DataAnnotationsValidator />
            <!-- Username field -->
            <div class="form-group">
                <label for="username" class="form-label">Username</label>
                <div class="input-wrapper">
                    <i class="pi pi-user input-icon"></i>
                    <InputText id="username"
                               @bind-Value="Model!.Username"
                               class="form-input"
                               placeholder="Enter your username" />
                </div>
                <ValidationMessage class="error-message" For="() => Model!.Username" />
            </div>

            <!-- Password field -->
            <div class="form-group">
                <label for="password" class="form-label">Password</label>
                <div class="input-wrapper">
                    <i class="pi pi-lock input-icon"></i>
                    <InputText id="password"
                               type="password"
                               @bind-Value="Model!.Password"
                               class="form-input"
                               placeholder="Enter your password" />
                </div>
                <ValidationMessage class="error-message" For="() => Model!.Password" />
            </div>

            <!-- Remember me -->
            <div class="form-options">
                <label class="checkbox-wrapper">
                    <input type="checkbox" id="rememberMe" @bind="Model!.RememberMe" class="glass-checkbox-input" />
                    <span class="glass-checkbox"></span>
                    <span class="checkbox-text">Remember me</span>
                </label>
            </div>

            <!-- Error message -->
            @if (!string.IsNullOrEmpty(AuthError))
            {
                <div class="error-message">@AuthError</div>
            }

            <!-- Submit button -->
            <button type="submit" class="submit-btn">
                <span>Sign In</span>
            </button>
        </EditForm>

        <!-- Sign up link -->
        <div class="card-footer">
            <p class="signup-text">
                Don't have an account?
                <a href="/signup" class="signup-link">Sign up</a>
            </p>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromForm]
    private LoginModel? Model { get; set; }

    private string? AuthError;

    private class LoginModel
    {
        [Required(ErrorMessage = "Username is required")]
        public string Username { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required")]
        public string Password { get; set; } = string.Empty;

        public bool RememberMe { get; set; } = false;
    }

    protected override void OnInitialized()
    {
        Model ??= new();
    }

    private void OnInvalidSubmit(EditContext context)
    {
        // Validation messages are shown automatically by ValidationMessage components
    }

    private async Task OnValidSubmit(EditContext context)
    {
        AuthError = null;

        try
        {
            // Sign in using SignInManager (creates cookie authentication)
            var result = await SignInManager.PasswordSignInAsync(
                Model!.Username, Model!.Password, isPersistent: Model.RememberMe, lockoutOnFailure: false);

            if (!result.Succeeded)
            {
                AuthError = "Invalid username or password";
                return;
            }

            // Check if this is part of an OAuth flow
            var httpContext = HttpContextAccessor.HttpContext;
            if (httpContext != null && !string.IsNullOrEmpty(ReturnUrl))
            {
                // Parse the returnUrl to check if it's the authorize endpoint
                if (ReturnUrl.Contains("/connect/authorize", StringComparison.OrdinalIgnoreCase))
                {
                    // Use server-side redirect for OAuth flow to avoid multiple roundtrips
                    httpContext.Response.Redirect(ReturnUrl, permanent: false);
                    return;
                }
            }

            // For non-OAuth flows, use NavigationManager
            NavManager.NavigateTo(ReturnUrl ?? "/", forceLoad: true);
        }
        catch (Exception ex)
        {
            AuthError = $"Sign in failed: {ex.Message}";
        }
    }
}
