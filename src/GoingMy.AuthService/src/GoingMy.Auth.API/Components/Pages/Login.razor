@page "/"
@page "/login"
@using GoingMy.Auth.API.Services
@using GoingMy.Auth.API.Dtos
@using System.Net.Http.Json
@using System.Text.Json
@using System.ComponentModel.DataAnnotations
@inject IUserService UserService
@inject NavigationManager NavManager
@inject IHttpClientFactory HttpClientFactory
@rendermode InteractiveServer

<div class="login-container">
    <!-- Animated gradient background -->
    <div class="gradient-bg"></div>
    <div class="gradient-bg-overlay"></div>

    <!-- Glass card -->
    <div class="glass glass-card">
        <div class="card-header">
            <h1 class="title">Welcome Back</h1>
            <p class="subtitle">Sign in to continue to your account</p>
        </div>

        <EditForm Model="Model" FormName="login-form" OnValidSubmit="OnValidSubmit" OnInvalidSubmit="OnInvalidSubmit" class="login-form">
            <DataAnnotationsValidator />
            <!-- Username field -->
            <div class="form-group">
                <label for="username" class="form-label">Username</label>
                <div class="input-wrapper">
                    <i class="pi pi-user input-icon"></i>
                    <InputText
                        id="username"
                        @bind-Value="Model.Username"
                        class="form-input"
                        placeholder="Enter your username"
                        disabled="@IsLoading" />
                </div>
                <ValidationMessage class="error-message" For="() => Model.Username" />
            </div>

            <!-- Password field -->
            <div class="form-group">
                <label for="password" class="form-label">Password</label>
                <div class="input-wrapper">
                    <i class="pi pi-lock input-icon"></i>
                    <InputText
                        id="password"
                        type="password"
                        @bind-Value="Model.Password"
                        class="form-input"
                        placeholder="Enter your password"
                        disabled="@IsLoading" />
                </div>
                <ValidationMessage class="error-message" For="() => Model.Password" />
            </div>

            <!-- Remember me -->
            <div class="form-options">
                <div class="checkbox-wrapper">
                    <input type="checkbox" id="rememberMe" disabled />
                    <label for="rememberMe" class="checkbox-text">Remember me</label>
                </div>
            </div>

            <!-- Error message -->
            @if (!string.IsNullOrEmpty(AuthError))
            {
                <div class="error-alert">@AuthError</div>
            }

            <!-- Submit button -->
            <button type="submit" class="submit-btn" disabled="@IsLoading">
                @if (IsLoading)
                {
                    <span>Signing in...</span>
                }
                else
                {
                    <span>Sign In</span>
                }
            </button>
        </EditForm>

        <!-- Sign up link -->
        <div class="card-footer">
            <p class="signup-text">
                Don't have an account?
                <a href="/signup" class="signup-link">Sign up</a>
            </p>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    private string? ReturnUrl { get; set; }

    private LoginModel Model = new();
    private bool IsLoading = false;
    private string? AuthError = null;

    private class LoginModel
    {
        [Required(ErrorMessage = "Username is required")]
        public string Username { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required")]
        public string Password { get; set; } = string.Empty;
    }

    private void OnInvalidSubmit(EditContext context)
    {
        // Validation messages are shown automatically by ValidationMessage components
    }

    private async Task OnValidSubmit(EditContext context)
    {
        IsLoading = true;
        AuthError = null;

        try
        {
            // Validate credentials
            var user = await UserService.ValidateCredentialsAsync(Model.Username, Model.Password);
            
            if (user == null)
            {
                AuthError = "Invalid username or password";
                IsLoading = false;
                return;
            }

            // Request token from OpenIddict endpoint
            var tokenRequest = new Dictionary<string, string>
            {
                { "grant_type", "password" },
                { "username", Model.Username },
                { "password", Model.Password },
                { "client_id", "web-client" },
                { "scope", "social_api email profile roles openid" }
            };

            using var Http = HttpClientFactory.CreateClient();
            Http.BaseAddress = new Uri(NavManager.BaseUri);

            var response = await Http.PostAsync("/connect/token", new FormUrlEncodedContent(tokenRequest));
            
            if (!response.IsSuccessStatusCode)
            {
                AuthError = "Authentication failed. Please try again.";
                IsLoading = false;
                return;
            }

            var tokenJson = await response.Content.ReadAsStringAsync();
            using var doc = JsonDocument.Parse(tokenJson);
            var root = doc.RootElement;

            if (!root.TryGetProperty("access_token", out var tokenEl))
            {
                AuthError = "Failed to obtain access token";
                return;
            }

            var accessToken = tokenEl.GetString();
            var expiresIn = root.TryGetProperty("expires_in", out var expEl) ? expEl.GetInt32() : 900;

            // Build redirect URL back to Angular with token in query params
            var callbackBase = ReturnUrl ?? "http://localhost:4200/signin-oidc";
            var separator = callbackBase.Contains('?') ? "&" : "?";
            var redirectUrl = $"{callbackBase}{separator}access_token={Uri.EscapeDataString(accessToken ?? string.Empty)}&expires_in={expiresIn}&token_type=bearer";

            NavManager.NavigateTo(redirectUrl, forceLoad: true);
        }
        catch (Exception ex)
        {
            AuthError = $"Sign in failed: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }
}
