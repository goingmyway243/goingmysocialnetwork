@page "/signup"
@using GoingMy.Auth.API.Dtos
@using System.Net.Http.Json
@using System.Text.Json
@inject NavigationManager NavManager
@inject IHttpClientFactory HttpClientFactory
@rendermode InteractiveServer

<div class="login-container">
    <!-- Animated gradient background -->
    <div class="gradient-bg"></div>
    <div class="gradient-bg-overlay"></div>

    <!-- Glass card -->
    <div class="glass glass-card">
        <div class="card-header">
            <h1 class="title">Create Account</h1>
            <p class="subtitle">Join our social network today</p>
        </div>

        <form @onsubmit="OnSubmit" class="login-form">
            <!-- Email field -->
            <div class="form-group">
                <label for="email" class="form-label">Email</label>
                <div class="input-wrapper">
                    <i class="pi pi-envelope input-icon"></i>
                    <input
                        id="email"
                        type="email"
                        @bind="Email"
                        @bind:event="oninput"
                        class="form-input"
                        placeholder="Enter your email"
                        disabled="@IsLoading"
                    />
                </div>
                @if (!string.IsNullOrEmpty(ValidationErrors.GetValueOrDefault("email")))
                {
                    <span class="error-message">@ValidationErrors["email"]</span>
                }
            </div>

            <!-- Username field -->
            <div class="form-group">
                <label for="username" class="form-label">Username</label>
                <div class="input-wrapper">
                    <i class="pi pi-user input-icon"></i>
                    <input
                        id="username"
                        type="text"
                        @bind="Username"
                        @bind:event="oninput"
                        class="form-input"
                        placeholder="Choose a username"
                        disabled="@IsLoading"
                    />
                </div>
                @if (!string.IsNullOrEmpty(ValidationErrors.GetValueOrDefault("username")))
                {
                    <span class="error-message">@ValidationErrors["username"]</span>
                }
            </div>

            <!-- Password field -->
            <div class="form-group">
                <label for="password" class="form-label">Password</label>
                <div class="input-wrapper">
                    <i class="pi pi-lock input-icon"></i>
                    <input
                        id="password"
                        type="password"
                        @bind="Password"
                        @bind:event="oninput"
                        class="form-input"
                        placeholder="Create a password"
                        disabled="@IsLoading"
                    />
                </div>
                @if (!string.IsNullOrEmpty(ValidationErrors.GetValueOrDefault("password")))
                {
                    <span class="error-message">@ValidationErrors["password"]</span>
                }
            </div>

            <!-- Confirm Password field -->
            <div class="form-group">
                <label for="confirm-password" class="form-label">Confirm Password</label>
                <div class="input-wrapper">
                    <i class="pi pi-lock input-icon"></i>
                    <input
                        id="confirm-password"
                        type="password"
                        @bind="ConfirmPassword"
                        @bind:event="oninput"
                        class="form-input"
                        placeholder="Confirm your password"
                        disabled="@IsLoading"
                    />
                </div>
                @if (!string.IsNullOrEmpty(ValidationErrors.GetValueOrDefault("confirmPassword")))
                {
                    <span class="error-message">@ValidationErrors["confirmPassword"]</span>
                }
            </div>

            <!-- Error message -->
            @if (!string.IsNullOrEmpty(AuthError))
            {
                <div class="error-alert">@AuthError</div>
            }

            <!-- Submit button -->
            <button type="submit" class="submit-btn" disabled="@IsLoading">
                @if (IsLoading)
                {
                    <span>Creating account...</span>
                }
                else
                {
                    <span>Sign Up</span>
                }
            </button>
        </form>

        <!-- Sign in link -->
        <div class="card-footer">
            <p class="signup-text">
                Already have an account?
                <a href="/login" class="signup-link">Sign in</a>
            </p>
        </div>
    </div>
</div>

@code {
    private string Email = string.Empty;
    private string Username = string.Empty;
    private string Password = string.Empty;
    private string ConfirmPassword = string.Empty;
    private bool IsLoading = false;
    private string? AuthError = null;
    private Dictionary<string, string> ValidationErrors = new();

    private async Task OnSubmit()
    {
        IsLoading = true;
        AuthError = null;
        ValidationErrors.Clear();

        try
        {
            // Client-side validation
            if (string.IsNullOrWhiteSpace(Email))
            {
                ValidationErrors["email"] = "Email is required";
            }
            if (string.IsNullOrWhiteSpace(Username))
            {
                ValidationErrors["username"] = "Username is required";
            }
            if (string.IsNullOrWhiteSpace(Password))
            {
                ValidationErrors["password"] = "Password is required";
            }
            if (Password != ConfirmPassword)
            {
                ValidationErrors["confirmPassword"] = "Passwords do not match";
            }

            if (ValidationErrors.Any())
            {
                IsLoading = false;
                return;
            }

            // Call signup endpoint
            var signupRequest = new SignupRequest
            {
                Email = Email,
                Username = Username,
                Password = Password
            };

            using var Http = HttpClientFactory.CreateClient();
            Http.BaseAddress = new Uri(NavManager.BaseUri);

            var response = await Http.PostAsJsonAsync("/api/user/signup", signupRequest);
            
            if (response.IsSuccessStatusCode)
            {
                // Redirect to login on success
                NavManager.NavigateTo("/login?signup=success");
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                AuthError = "Username or email already taken";
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
            {
                var contentString = await response.Content.ReadAsStringAsync();
                var error = JsonSerializer.Deserialize<ErrorResponse>(contentString);
                AuthError = error?.Message ?? "Invalid input. Please check your details.";
            }
            else
            {
                AuthError = "Sign up failed. Please try again.";
            }
        }
        catch (Exception ex)
        {
            AuthError = $"Sign up failed: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private class SignupRequest
    {
        public string Email { get; set; } = string.Empty;
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }

    private class ErrorResponse
    {
        public string Message { get; set; } = string.Empty;
    }
}
